# ----- Site -----
NEXT_PUBLIC_SITE_URL=https://hyperdial.io

# ----- Demo scheduler (Google Calendar Appointment Scheduling) -----
# Paste the "embed" URL of your Google appointment schedule (ends with the booking page).
NEXT_PUBLIC_GCAL_SCHEDULE_URL=

# ----- Lead storage: Supabase -----
# Project Settings -> API. Use the SERVICE ROLE key (server-only, never expose client-side).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Lead notifications: Resend (email) -----
# https://resend.com -> API keys. From-address must be on a verified domain.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=deepak@hyperdial.io
LEAD_FROM_EMAIL=HyperDial <hello@hyperdial.io>
